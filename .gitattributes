# 自动处理行尾符
* text=auto eol=lf

# 源代码文件统一使用 UTF-8
*.java text encoding=utf-8
*.py text encoding=utf-8
*.xml text encoding=utf-8
*.yml text encoding=utf-8
*.yaml text encoding=utf-8
*.properties text encoding=utf-8
*.sql text encoding=utf-8
*.md text encoding=utf-8
*.txt text encoding=utf-8
*.json text encoding=utf-8
*.log text encoding=utf-8
*.conf text encoding=utf-8

# 前端文件
*.vue text encoding=utf-8
*.js text encoding=utf-8
*.mjs text encoding=utf-8
*.cjs text encoding=utf-8
*.ts text encoding=utf-8
*.jsx text encoding=utf-8
*.tsx text encoding=utf-8
*.html text encoding=utf-8
*.htm text encoding=utf-8
*.css text encoding=utf-8
*.scss text encoding=utf-8
*.less text encoding=utf-8
*.wxml text encoding=utf-8
*.wxss text encoding=utf-8

# 确保 shell 脚本使用 LF
*.sh text eol=lf

# 确保 Windows 批处理使用 CRLF
*.bat text eol=crlf

