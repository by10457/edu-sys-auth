# ─────────────────────────────────────────────────────────────
# edu-sys-auth Worker 环境变量模板
#
# 使用方式：
#   cp .env.example .env
#   然后按照实际情况修改 .env 中的值
# ─────────────────────────────────────────────────────────────

# ── Redis 连接配置 ───────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── 浏览器池配置 ─────────────────────────────────────────────
# 总并发数 = BROWSER_COUNT × CONTEXTS_PER_BROWSER
#
# 【本地开发】低配置，够测试就行
#   BROWSER_COUNT=2
#   CONTEXTS_PER_BROWSER=5
#   → 10 并发，内存 ~550MB
#
# 【服务器生产（单进程）】62GB/56核 服务器推荐
#   BROWSER_COUNT=8
#   CONTEXTS_PER_BROWSER=10
#   → 80 并发，内存 ~3.6GB
#
# 【服务器生产（多进程，可运行多个 worker:dev）】
#   每个进程使用较小配置，多进程自动分摊队列
#   BROWSER_COUNT=4
#   CONTEXTS_PER_BROWSER=10
#   → 每进程 40 并发；起 2 个进程 = 总 80 并发
#
BROWSER_COUNT=2
CONTEXTS_PER_BROWSER=5
