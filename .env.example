# ─────────────────────────────────────────────────────────────
# edu-sys-auth Worker 环境变量模板
#
# 使用方式：
#   cp .env.example .env
#   然后按照实际情况修改 .env 中的值
# ─────────────────────────────────────────────────────────────

# ── Redis 连接配置 ───────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── 浏览器池配置 ─────────────────────────────────────────────
# 总并发数 = BROWSER_COUNT × CONTEXTS_PER_BROWSER
#
# 【本地开发 - 无头（默认）】够测试就行
#   BROWSER_COUNT=2
#   CONTEXTS_PER_BROWSER=5
#   → 10 并发，内存 ~550MB
#
# 【本地开发 - 有头（可视化调试）】建议降低并发，避免开过多浏览器窗口
#   HEADLESS=false       # 开启有头模式，浏览器窗口可见
#   BROWSER_COUNT=1      # 1 个浏览器（自动默认值）
#   CONTEXTS_PER_BROWSER=2   # 2 个 Tab（自动默认值）
#   → 2 并发，可清晰观察每个自动化登录过程
#   启动方式：npm run dev:worker:headed 或 npm run dev:all:headed
#
# 【服务器生产（单进程）】62GB/56核 服务器推荐
#   BROWSER_COUNT=8
#   CONTEXTS_PER_BROWSER=10
#   → 80 并发，内存 ~3.6GB
#
# 【服务器生产（多进程，可运行多个 worker:dev）】
#   每个进程使用较小配置，多进程自动分摊队列
#   BROWSER_COUNT=4
#   CONTEXTS_PER_BROWSER=10
#   → 每进程 40 并发；起 2 个进程 = 总 80 并发
#
BROWSER_COUNT=2
CONTEXTS_PER_BROWSER=5

# ── 浏览器有头/无头模式 ──────────────────────────────────────
# true（默认）：无头模式，适合生产环境，性能最优，无窗口
# false：有头模式，适合开发调试，浏览器窗口可见，并发自动降低
# 注意：有头模式不适合生产，会占用桌面 GUI 资源
HEADLESS=true

