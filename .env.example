# ─────────────────────────────────────────────────────────────
# edu-sys-auth Worker 环境变量模板
#
# 使用方式：
#   cp .env.example .env
#   然后按照实际情况修改 .env 中的值
# ─────────────────────────────────────────────────────────────

# ── Redis 连接配置 ───────────────────────────────────────────
# 必须与 edu-sys-spider 使用同一个 Redis 实例和 DB，
# auth 会额外写入 spider:login_session:{cid}:{sid}:{type} 兼容缓存。
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── MySQL 会话持久化（edu-sys-spider DB fallback）──────────────
# 登录成功后额外 upsert 到 edu_user.spider_login_session。
# Redis 仍是主链路；MySQL 写入失败不会阻断登录。
MYSQL_ENABLED=true
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=edu_user
MYSQL_CONNECTION_LIMIT=3

# ── 浏览器池配置 ─────────────────────────────────────────────
# 总并发数 = BROWSER_COUNT × CONTEXTS_PER_BROWSER
#
# 【本地开发 - 无头（默认）】够测试就行
#   BROWSER_COUNT=2
#   CONTEXTS_PER_BROWSER=5
#   → 10 并发，内存 ~550MB
#
# 【本地开发 - 有头（可视化调试）】建议降低并发，避免开过多浏览器窗口
#   HEADLESS=false       # 开启有头模式，浏览器窗口可见
#   BROWSER_COUNT=1      # 1 个浏览器（自动默认值）
#   CONTEXTS_PER_BROWSER=2   # 2 个 Tab（自动默认值）
#   → 2 并发，可清晰观察每个自动化登录过程
#   启动方式：npm run dev:worker:headed 或 npm run dev:all:headed
#
# 【服务器生产（单进程）】62GB/56核 服务器推荐
#   BROWSER_COUNT=8
#   CONTEXTS_PER_BROWSER=10
#   → 80 并发，内存 ~3.6GB
#
# 【服务器生产（多进程，可运行多个 worker:dev）】
#   每个进程使用较小配置，多进程自动分摊队列
#   BROWSER_COUNT=4
#   CONTEXTS_PER_BROWSER=10
#   → 每进程 40 并发；起 2 个进程 = 总 80 并发
#
BROWSER_COUNT=2
CONTEXTS_PER_BROWSER=5

# ── 浏览器有头/无头模式 ──────────────────────────────────────
# true（默认）：无头模式，适合生产环境，性能最优，无窗口
# false：有头模式，适合开发调试，浏览器窗口可见，并发自动降低
# 注意：有头模式不适合生产，会占用桌面 GUI 资源
HEADLESS=true

# ── Context 与高并发保护 ────────────────────────────────────
# 默认每个任务结束后重建 Context，避免 localStorage/IndexedDB/ServiceWorker 污染。
RECYCLE_CONTEXT_AFTER_USE=true
# 关闭上方重建策略后，单个 Context 最多复用多少次。
MAX_CONTEXT_USAGE=50
# 无空闲 Context 时，单个任务最多等待多久。
ACQUIRE_TIMEOUT_MS=30000
# 等待 Context 的最大排队数，超出后快速失败，避免瞬时洪峰占满内存。
# 默认建议值：BROWSER_COUNT × CONTEXTS_PER_BROWSER × 4。
MAX_PENDING_ACQUIRES=40
# BullMQ 任务锁超时时间，应略大于单次登录最大耗时。
JOB_LOCK_DURATION_MS=75000
# 自动化异常重试次数和指数退避初始延迟；凭据错误不会重试。
LOGIN_JOB_ATTEMPTS=3
LOGIN_JOB_BACKOFF_DELAY_MS=2000

# ── OCR 服务 ───────────────────────────────────────────────
# 使用与 edu-sys-spider 一致的 ddddocr HTTP 服务协议。
OCR_API_URL=http://103.120.88.218:10466/ocr
OCR_TIMEOUT_MS=10000
